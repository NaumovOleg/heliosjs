{
  "name": "quantum-flow",
  "version": "1.0.1",
  "description": "Decorator-based API framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --config ./nodemon.json",
    "prepublishOnly": "yarn build"
  },
  "exports": {
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./http": {
      "import": "./dist/app/http/index.js",
      "require": "./dist/app/http/index.js",
      "types": "./dist/app/http/index.d.ts"
    },
    "./aws": {
      "import": "./dist/app/aws/index.js",
      "require": "./dist/app/aws/index.js",
      "types": "./dist/app/aws/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/your-repo.git"
  },
  "keywords": [
    "api",
    "decorators",
    "http",
    "websocket",
    "typescript",
    "aws",
    "rest"
  ],
  "author": "Naumov Oleh",
  "dependencies": {
    "aws-lambda": "^1.0.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "parse-multipart-data": "^1.5.0",
    "reflect-metadata": "^0.2.2",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0",
    "ts-node": ">=10.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "nodemon": "^3.1.14",
    "typescript-eslint": "^8.56.1"
  }
}
