{
  "name": "heliosjs",
  "version": "1.0.0",
  "description": "Decorator-based API framework",
  "main": "dist/index.js",
  "private": true,
  "type": "module",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn build:core && yarn build:http && yarn build:aws && yarn build:middlewares && yarn build:grpc",
    "build:core": "yarn workspace @heliosjs/core run build",
    "build:http": "yarn workspace @heliosjs/http run build",
    "build:aws": "yarn workspace @heliosjs/aws run build",
    "build:grpc": "yarn workspace @heliosjs/grpc run build",
    "build:middlewares": "yarn workspace @heliosjs/middlewares run build",
    "dev": "nodemon --config ./nodemon.json",
    "link-packages": "chmod +x ./setup-symlinks.sh && ./setup-symlinks.sh",
    "make-tag": "changeset tag",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance --access public"
  },
  "workspaces": ["src/core", "src/middlewares", "src/http", "src/aws", "src/grpc"],
  "repository": {
    "type": "git",
    "url": "https://github.com/NaumovOleg/heliosjs"
  },
  "keywords": [
    "api",
    "decorators",
    "http",
    "rest",
    "websocket",
    "typescript",
    "aws",
    "lambda",
    "graphql"
  ],
  "author": "Naumov Oleh",
  "peerDependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "aws-lambda": "^1.0.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "graphql": "^16.13.1",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^6.0.7",
    "graphql-yoga": "^5.18.1",
    "jest": "^30.3.0",
    "joi": "^18.0.2",
    "nodemon": "^3.1.14",
    "parse-multipart-data": "^1.5.0",
    "reflect-metadata": "^0.2.2",
    "ts-node": ">=10.9.2",
    "tsconfig-paths": "^4.2.0",
    "type-graphql": "^2.0.0-rc.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "http": "^0.0.1-security",
    "rxjs": "^7.8.2",
    "url": "^0.11.4"
  }
}
