{
  "version": "independent",
  "npmClient": "yarn",
  "packages": ["src/core", "src/http", "src/aws", "src/middlewares"],
  "command": {
    "version": {
      "conventionalCommits": true,
      "message": "chore(release): publish",
      "createRelease": "github",
      "tagPrefix": "heliosjs",
      "allowBranch": ["master", "main"],
      "ignoreChanges": ["**/*.md", "**/test/**", "**/__tests__/**"]
    },
    "publish": {
      "registry": "https://registry.npmjs.org/",
      "access": "public",
      "verifyAccess": true,
      "verifyRegistry": true
    }
  },
  "ignoreChanges": ["**/*.md", "**/test/**", "**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
  "changelogPreset": "conventionalcommits"
}
