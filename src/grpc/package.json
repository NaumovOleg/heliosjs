{
  "name": "@heliosjs/grpc",
  "version": "1.1.0",
  "description": "Grpc support for @heliosjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaumovOleg/heliosjs.git",
    "directory": "src/grpc"
  },
  "files": [
    "dist/*",
    "README.md"
  ],
  "scripts": {
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn build",
    "publish:public": "yarn publish --access public --no-git-tag-version",
    "publish:patch": "yarn version --patch --no-git-tag-version && yarn publish --access public",
    "publish:minor": "yarn version --minor --no-git-tag-version && yarn publish --access public",
    "publish:major": "yarn version --major --no-git-tag-version && yarn publish --access public"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@types/node": "^25.5.0",
    "reflect-metadata": "^0.2.2",
    "typescript": ">=4.0.0"
  }
}
