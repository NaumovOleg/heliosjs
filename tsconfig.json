{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "es2022",
    "types": [
      "node"
    ],
    "preserveSymlinks": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ],
    "paths": {
      "@controllers": [
        "./src/controllers/index.ts"
      ],
      "@utils": [
        "./src/utils/index.ts"
      ],
      "@types": [
        "./src/types/index.ts"
      ],
      "@validators": [
        "./src/validators/index.ts"
      ],
      "@constants": [
        "./src/constants.ts"
      ]
    },
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
  ]
}